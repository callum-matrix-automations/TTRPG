{
  "name": "ttrpg",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main.js",
  "description": "AI-powered tabletop RPG",
  "scripts": {
    "dev:next": "next dev",
    "dev:electron": "wait-on http://localhost:3000 && electron .",
    "dev": "concurrently --kill-others \"npm run dev:next\" \"cross-env NODE_ENV=development npm run build:electron && npm run dev:electron\"",
    "build:next": "next build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:next && npm run build:electron",
    "dist": "npm run build && electron-builder",
    "lint": "next lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/callum-matrix-automations/TTRPG.git"
  },
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/callum-matrix-automations/TTRPG/issues"
  },
  "homepage": "https://github.com/callum-matrix-automations/TTRPG#readme",
  "dependencies": {
    "lucide-react": "^1.7.0",
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.ttrpg.app",
    "productName": "TTRPG",
    "files": [
      "dist-electron/**/*",
      "out/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
